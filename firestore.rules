rules_version = '2';

// Reglas de seguridad: cada usuario solo puede leer/escribir su propio documento.
service cloud.firestore {
  match /databases/{database}/documents {
    // /users/{uid}  -> documento principal con todo el estado financiero del usuario
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subcolecciones futuras (movimientos por separado, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
